# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
.directory

# Windows
Thumbs.db
desktop.ini

# IDEs and Editors
.idea/
*.iml
.vscode/
.history/
.zed/
*.swp
*.swo
*.code-workspace

# Temporary / backup
*~
*.log
*.bak
*.tmp

# ──────────────────────────────────────────────────────────────────────────
# Python (crawler / detection / shared)
# ──────────────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/
.tox/

# ──────────────────────────────────────────────────────────────────────────
# Node / Vite / React (dashboard)
# ──────────────────────────────────────────────────────────────────────────
node_modules/
dist/
*.tsbuildinfo
.vite/
.eslintcache
coverage/

# ──────────────────────────────────────────────────────────────────────────
# Gradle / Spring Boot (api)
# ──────────────────────────────────────────────────────────────────────────
.gradle/
build/
# *.class / *.jar는 trace 가능 — Gradle wrapper jar는 commit 필요하므로 패턴 화이트리스트:
*.class
!gradle/wrapper/*.jar

# ──────────────────────────────────────────────────────────────────────────
# Environment / secrets
# ──────────────────────────────────────────────────────────────────────────
.env
.env.local
*.env.local

# 시크릿 키/인증서 1차 가드 (실제 push 전 pre-commit `detect-private-key`도 실행)
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*credentials*.json
.aws-vault/

# Claude agents
.agents/

# ──────────────────────────────────────────────────────────────────────────
# Terraform (Story 5.3)
# ──────────────────────────────────────────────────────────────────────────
**/.terraform/
# .terraform.lock.hcl은 commit 권장 (best practice — provider 버전 일관성 보장)
*.tfstate
*.tfstate.*
*.tfplan
plan.txt
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
# tfvars: example만 commit, 실제 값은 제외
infra/terraform/**/terraform.tfvars
infra/terraform/**/*.auto.tfvars
infra/terraform/**/*.auto.tfvars.json
!infra/terraform/**/terraform.tfvars.example

# CI / security 도구 출력
results.sarif
checkov-report.*
tflint-report.*
